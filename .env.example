# Auth9 Environment Configuration
# Copy this file to .env and customize values

# [DEPRECATED] Keycloak credentials — only needed when IDENTITY_BACKEND=keycloak
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=admin
# KEYCLOAK_ADMIN_CLIENT_ID=auth9-admin
# KEYCLOAK_ADMIN_CLIENT_SECRET=dev-client-secret-change-in-production

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key

# RSA keys for JWT signing (RS256). Use \n for line breaks in the value.
# Quick setup: run scripts/init-dev-env.sh to auto-generate all secrets.
# Manual generation:
#   openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt > /tmp/jwt.key
#   openssl rsa -pubout < /tmp/jwt.key > /tmp/jwt.pub
#   Then paste with \n replacing newlines.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# Previous public key for key rotation (optional, leave empty if not rotating)
JWT_PREVIOUS_PUBLIC_KEY=

# Session Secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your-session-secret

# Identity backend selection
IDENTITY_BACKEND=auth9_oidc

# Password Reset Security (generate with: openssl rand -hex 32)
PASSWORD_RESET_HMAC_KEY=your-password-reset-hmac-key-change-in-production
PASSWORD_RESET_TOKEN_TTL_SECS=3600

# gRPC Security Configuration
# Options: "none", "api_key", "mtls"
# GRPC_AUTH_MODE=none
# GRPC_API_KEYS=key1,key2,key3

# gRPC mTLS Configuration (for auth_mode=mtls)
# GRPC_TLS_CERT_PATH=/path/to/server.crt
# GRPC_TLS_KEY_PATH=/path/to/server.key
# GRPC_TLS_CA_CERT_PATH=/path/to/ca.crt

# Settings encryption key for sensitive data (REQUIRED, generate with: openssl rand -base64 32)
SETTINGS_ENCRYPTION_KEY=
