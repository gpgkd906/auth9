# Auth9 Secrets Template
# Copy this file to secrets.yaml and fill in actual values
# DO NOT commit secrets.yaml to version control!
#
# Create secrets with:
#   kubectl create secret generic auth9-secrets \
#     --from-literal=DATABASE_URL='mysql://user:pass@host:4000/auth9' \  # pragma: allowlist secret
#     --from-literal=REDIS_URL='redis://host:6379' \
#     --from-literal=JWT_SECRET='your-jwt-secret' \  # pragma: allowlist secret
#     --from-literal=JWT_PRIVATE_KEY='your-rsa-private-key-pem' \  # pragma: allowlist secret
#     --from-literal=JWT_PUBLIC_KEY='your-rsa-public-key-pem' \
#     --from-literal=SESSION_SECRET='your-session-secret' \  # pragma: allowlist secret
#     --from-literal=GRPC_API_KEYS='your-grpc-api-key' \  # pragma: allowlist secret
#     -n auth9

apiVersion: v1
kind: Secret
metadata:
  name: auth9-secrets
  namespace: auth9
  labels:
    app.kubernetes.io/name: auth9
type: Opaque
stringData:
  # Database connection string (TiDB)
  DATABASE_URL: "mysql://root:password@tidb-cluster:4000/auth9" # pragma: allowlist secret

  # Redis connection string
  REDIS_URL: "redis://redis-cluster:6379"

  # JWT signing secret (generate with: openssl rand -hex 32)
  JWT_SECRET: "CHANGE_ME_generate_with_openssl_rand_hex_32" # pragma: allowlist secret

  # JWT RSA key pair for RS256 token signing (required)
  # Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
  JWT_PRIVATE_KEY: "<YOUR_RSA_PRIVATE_KEY_PEM>"
  JWT_PUBLIC_KEY: "<YOUR_RSA_PUBLIC_KEY_PEM>"

  # Auth9 seeded admin password (keep stable across re-runs)
  # If omitted, deploy.sh will generate a strong password once and prompt you to save it.
  AUTH9_ADMIN_PASSWORD: "CHANGE_ME_strong_password" # pragma: allowlist secret

  # Seeded Auth9 platform admin email for the initial admin account
  AUTH9_ADMIN_EMAIL: "admin@auth9.local"

  # Session secret for portal (generate with: openssl rand -hex 32)
  SESSION_SECRET: "CHANGE_ME_generate_with_openssl_rand_hex_32" # pragma: allowlist secret

  # Webhook HMAC secret for event signature verification (generate with: openssl rand -hex 32)
  KEYCLOAK_WEBHOOK_SECRET: "CHANGE_ME_generate_with_openssl_rand_hex_32" # pragma: allowlist secret

  # Settings encryption key (AES-256, generate with: openssl rand -base64 32)
  # Used to encrypt sensitive tenant settings in database
  SETTINGS_ENCRYPTION_KEY: "CHANGE_ME_generate_with_openssl_rand_base64_32" # pragma: allowlist secret

  # Password reset HMAC key (generate with: openssl rand -hex 32)
  PASSWORD_RESET_HMAC_KEY: "CHANGE_ME_generate_with_openssl_rand_hex_32" # pragma: allowlist secret

  # gRPC API key for securing gRPC endpoints (generate with: openssl rand -base64 32)
  GRPC_API_KEYS: "CHANGE_ME_generate_with_openssl_rand_base64_32" # pragma: allowlist secret
